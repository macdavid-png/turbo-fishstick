<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="v1">Next Trade Condition</variable>
    <variable id="v2">Max Acceptable Loss</variable>
    <variable id="v3">Initial Amount</variable>
    <variable id="v4">Expected Profit</variable>
    <variable id="v5">Win Amount</variable>
  </variables>
  <block type="trade_definition" id="main" x="0" y="0">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="m1">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">R_100</field>
        <next>
          <block type="trade_definition_tradetype" id="t1">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">evenodd</field>
            <next>
              <block type="trade_definition_candleinterval" id="c1">
                <field name="CANDLEINTERVAL_LIST">60</field>
                <next>
                  <block type="trade_definition_restartonerror" id="r1">
                    <field name="RESTARTONERROR">TRUE</field>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="INITIALIZATION">
      <block type="variables_set" id="i1">
        <field name="VAR" id="v1">Next Trade Condition</field>
        <value name="VALUE"><block type="text" id="tx1"><field name="TEXT">Even</field></block></value>
        <next>
          <block type="variables_set" id="i2">
            <field name="VAR" id="v2">Max Acceptable Loss</field>
            <value name="VALUE"><block type="math_number" id="n1"><field name="NUM">100</field></block></value>
            <next>
              <block type="variables_set" id="i3">
                <field name="VAR" id="v3">Initial Amount</field>
                <value name="VALUE"><block type="math_number" id="n2"><field name="NUM">1</field></block></value>
                <next>
                  <block type="variables_set" id="i4">
                    <field name="VAR" id="v5">Win Amount</field>
                    <value name="VALUE"><block type="math_number" id="n3"><field name="NUM">1</field></block></value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="opt">
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION"><block type="math_number" id="d1"><field name="NUM">1</field></block></value>
        <value name="AMOUNT"><block type="variables_get" id="g1"><field name="VAR" id="v3">Initial Amount</field></block></value>
      </block>
    </statement>
  </block>
  <block type="before_purchase" id="bp" x="0" y="650">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="controls_if" id="if1">
        <mutation else="1"></mutation>
        <value name="IF0">
          <block type="logic_compare" id="c1">
            <field name="OP">EQ</field>
            <value name="A"><block type="variables_get" id="gv1"><field name="VAR" id="v1">Next Trade Condition</field></block></value>
            <value name="B"><block type="text" id="te1"><field name="TEXT">Even</field></block></value>
          </block>
        </value>
        <statement name="DO0"><block type="mon_purchase" id="p1"><field name="PURCHASE_LIST">DIGITEVEN</field></block></statement>
        <statement name="ELSE"><block type="mon_purchase" id="p2"><field name="PURCHASE_LIST">DIGITODD</field></block></statement>
      </block>
    </statement>
  </block>
  <block type="after_purchase" id="ap" x="750" y="0">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="stoploss">
        <value name="IF0">
          <block type="logic_compare" id="check1">
            <field name="OP">LT</field>
            <value name="A"><block type="variables_get" id="g_loss"><field name="VAR" id="v3">Initial Amount</field></block></value>
            <value name="B"><block type="variables_get" id="g_max"><field name="VAR" id="v2">Max Acceptable Loss</field></block></value>
          </block>
        </value>
        <statement name="DO0">
          <block type="controls_if" id="res">
            <mutation else="1"></mutation>
            <value name="IF0"><block type="contract_check_result" id="loss"><field name="CHECK_RESULT">loss</field></block></value>
            <statement name="DO0">
              <block type="variables_set" id="s1">
                <field name="VAR" id="v1">Next Trade Condition</field>
                <value name="VALUE"><block type="text" id="t_o"><field name="TEXT">Odd</field></block></value>
                <next>
                  <block type="variables_set" id="m1">
                    <field name="VAR" id="v3">Initial Amount</field>
                    <value name="VALUE">
                      <block type="math_arithmetic" id="mult">
                        <field name="OP">MULTIPLY</field>
                        <value name="A"><block type="variables_get" id="gs1"><field name="VAR" id="v3">Initial Amount</field></block></value>
                        <value name="B"><block type="math_number" id="mn1"><field name="NUM">1.1</field></block></value>
                      </block>
                    </value>
                  </block>
                </next>
              </block>
            </statement>
            <statement name="ELSE">
              <block type="variables_set" id="s2">
                <field name="VAR" id="v1">Next Trade Condition</field>
                <value name="VALUE"><block type="text" id="te2"><field name="TEXT">Even</field></block></value>
                <next>
                  <block type="variables_set" id="reset">
                    <field name="VAR" id="v3">Initial Amount</field>
                    <value name="VALUE"><block type="variables_get" id="gw2"><field name="VAR" id="v5">Win Amount</field></block></value>
                  </block>
                </next>
              </block>
            </statement>
            <next><block type="trade_again" id="again"></block></next>
          </block>
        </statement>
      </block>
    </statement>
  </block>
</xml>
